# Supabase browser client. These two are safe to expose to the frontend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Supabase server functions. Keep the service role key server-side only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Paystack server functions. Keep this server-side only.
PAYSTACK_SECRET_KEY=sk_test_or_live_xxxxxxxxxxxxxxxxxxxxx

# Optional public site URL fallback used for Paystack callback URLs.
# Netlify deployments usually derive this from the request automatically.
# Local Netlify dev example: http://localhost:8888
URL=http://localhost:8888

# Comma-separated platform admin emails allowed to open /admin.
# Keep this server-side in Netlify env variables.
GLIDE_ADMIN_EMAILS=oluwadimimu.king@gmail.com
